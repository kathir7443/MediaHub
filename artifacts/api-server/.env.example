# API Server environment variables
# Copy this file to .env and fill in values for local development.
# On Render these are set in the service's "Environment" tab.

NODE_ENV=production

# Render sets PORT automatically. For local dev, set a port yourself.
PORT=3001

# Optional: restrict CORS to your Vercel frontend origin.
# Leave unset to allow all origins (suitable for development / open APIs).
# CORS_ORIGIN=https://your-mediahub.vercel.app

# Optional: override binary paths if yt-dlp / ffmpeg are not on PATH.
# Normally not needed — the server auto-detects them via `which`.
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
