# MediaHub frontend environment variables
# Copy this file to .env.local for local development.
# On Vercel these are set in the project's "Environment Variables" tab.

# Required when the frontend (Vercel) and API (Render) are on different origins.
# Set to the full origin of your Render API service — no trailing slash.
# VITE_API_BASE_URL=https://mediahub-api-3nww.onrender.com

# Leave unset for local dev or Replit — requests use relative /api/... paths.
